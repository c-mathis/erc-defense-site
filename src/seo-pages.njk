---
pagination:
  data: pages.pages
  size: 1
  alias: page
permalink: "/{{ page.slug }}/"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ page.title }}"
  description: "{{ page.description }}"
---
{%- set defined = page.content -%}

<!-- Hero Section -->
<section class="hero-sm">
    <div class="container">
        <div class="hero-content-center">
            {% if page.tag %}
            <span class="section-tag section-tag-danger">{{ page.tag }}</span>
            {% endif %}
            <h1 class="hero-title">{{ page.h1 | default(page.title) }}</h1>
            <p class="hero-subtitle">{{ page.description }}</p>
            <div class="hero-cta-group">
                <a href="#form" class="btn btn-primary btn-lg">Get Free Case Review</a>
                <a href="tel:{{ site.phoneRaw }}" class="btn btn-outline btn-lg">Call {{ site.phone }}</a>
            </div>
        </div>
    </div>
</section>

<!-- Urgency Banner (if applicable) -->
{% if page.content.urgency %}
<section style="background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%); padding: 1.5rem 0;">
    <div class="container">
        <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; color: white; text-align: center; flex-wrap: wrap;">
            <span style="font-size: 1.5rem;">&#9888;</span>
            <p style="margin: 0; font-weight: 600; font-size: 1.125rem;">{{ page.content.urgency }}</p>
        </div>
    </div>
</section>
{% endif %}

<!-- Main Content -->
<section class="section">
    <div class="container-sm">
        <div class="content-prose">
            <!-- Introduction -->
            {% if page.content.intro %}
            <p class="lead-text">{{ page.content.intro }}</p>
            {% endif %}

            <!-- Content Sections -->
            {% if page.content.sections %}
            {% for section in page.content.sections %}
            <h2>{{ section.heading }}</h2>
            {% if section.content %}
            {{ section.content | safe }}
            {% endif %}

            {% if section.list %}
            <ul>
                {% for item in section.list %}
                <li><strong>{{ item.title }}:</strong> {{ item.description }}</li>
                {% endfor %}
            </ul>
            {% endif %}

            {% if section.steps %}
            <ol>
                {% for step in section.steps %}
                <li><strong>{{ step.title }}:</strong> {{ step.description }}</li>
                {% endfor %}
            </ol>
            {% endif %}

            {% if section.warning %}
            <div class="callout callout-warning">
                <p><strong>Warning:</strong> {{ section.warning }}</p>
            </div>
            {% endif %}

            {% if section.tip %}
            <div class="callout callout-tip">
                <p><strong>Tip:</strong> {{ section.tip }}</p>
            </div>
            {% endif %}
            {% endfor %}
            {% endif %}

            <!-- Key Takeaways Box -->
            {% if page.content.takeaways %}
            <div class="takeaways-box">
                <h3>Key Takeaways</h3>
                <ul>
                    {% for takeaway in page.content.takeaways %}
                    <li>{{ takeaway }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        </div>
    </div>
</section>

<!-- FAQ Section with Schema -->
{% if page.faqs %}
<section class="section section-gray">
    <div class="container-sm">
        <div class="text-center" style="margin-bottom: 3rem;">
            <span class="section-tag">FAQ</span>
            <h2 class="section-title">Frequently Asked Questions</h2>
        </div>

        <div class="faq-list">
            {% for faq in page.faqs %}
            <details class="faq-item" {% if loop.first %}open{% endif %}>
                <summary>{{ faq.question }}<span class="faq-icon">+</span></summary>
                <div class="faq-answer">
                    <p>{{ faq.answer }}</p>
                </div>
            </details>
            {% endfor %}
        </div>
    </div>
</section>

<!-- FAQ Schema Markup -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in page.faqs %}
    {
      "@type": "Question",
      "name": "{{ faq.question }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ faq.answer }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<!-- Related Pages -->
{% if page.content.relatedPages %}
<section class="section">
    <div class="container-sm">
        <h2 class="section-title" style="text-align: center; margin-bottom: 2rem;">Related Resources</h2>
        <div class="related-grid">
            {% for related in page.content.relatedPages %}
            <a href="/{{ related.slug }}/" class="related-card">
                <span class="related-tag">{{ related.tag }}</span>
                <h3>{{ related.title }}</h3>
                <span class="related-link">Learn more &rarr;</span>
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- CTA Section -->
<section class="section" style="background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);">
    <div class="container">
        <div class="hero-grid">
            <div style="color: white;">
                <h2 class="section-title" style="color: white;">Get Expert Help Today</h2>
                <p style="color: rgba(255,255,255,0.8); font-size: 1.125rem; margin-bottom: 2rem;">
                    {% if page.content.ctaText %}
                    {{ page.content.ctaText }}
                    {% else %}
                    Don't navigate IRS issues alone. Our experienced team is ready to defend your ERC claim.
                    {% endif %}
                </p>
                <div class="hero-trust-badges" style="color: rgba(255,255,255,0.9);">
                    <span>&#10003; Experienced IRS Representation</span>
                    <span>&#10003; Former IRS Staff</span>
                    <span>&#10003; 100% Confidential</span>
                </div>
            </div>

            <!-- Lead Form -->
            <div id="form" class="lead-form-card">
                <span class="lead-form-badge">Free Review</span>
                <h3 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">Get Your Risk Assessment</h3>
                <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1.5rem;">Confidential analysis by experienced tax professionals.</p>

                <form data-lead-form>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <input type="text" name="firstName" placeholder="First Name" required class="form-input">
                        <input type="text" name="lastName" placeholder="Last Name" required class="form-input">
                    </div>
                    <div class="form-group">
                        <input type="email" name="email" placeholder="Business Email" required class="form-input">
                    </div>
                    <div class="form-group">
                        <input type="tel" name="phone" placeholder="Phone Number" required class="form-input">
                    </div>
                    <div class="form-group">
                        <select name="situation" required class="form-input form-select">
                            <option value="">What's your situation?</option>
                            <option value="audit">Received IRS Audit Notice</option>
                            <option value="letter">Received IRS Letter/Request</option>
                            <option value="denial">ERC Claim Denied</option>
                            <option value="pending">Claim Still Pending</option>
                            <option value="clawback">Received Clawback Notice</option>
                            <option value="proactive">Proactive Protection</option>
                        </select>
                    </div>
                    <button type="submit" class="form-submit">Start My Defense Review &rarr;</button>
                </form>
                <p style="text-align: center; font-size: 0.75rem; color: var(--text-light); margin-top: 1rem;">100% confidential. No obligation.</p>
            </div>
        </div>
    </div>
</section>
